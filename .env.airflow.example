# ============================================================
# Airflow 环境变量（示例）
# 复制为 .env.airflow 并填入真实值：
#   cp .env.airflow.example .env.airflow
# ============================================================

# 项目根目录
HOST_REPO_ROOT=F:/Projects/ecommerce-data-warehouse

# QQ 邮箱 SMTP 授权码
# 获取方式：QQ 邮箱 → 设置 → 账户 → POP3/SMTP 服务 → 生成授权码
SMTP_PASSWORD=your_qq_authorization_code_here
